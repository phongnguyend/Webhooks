@WebhookServer_HostAddress = https://localhost:7180

### Get all received requests
GET {{WebhookServer_HostAddress}}/
Accept: application/json

###

### Reset all received requests
GET {{WebhookServer_HostAddress}}/reset

###

### Post to /test endpoint
POST {{WebhookServer_HostAddress}}/test
Content-Type: application/json

{
  "event": "test_event",
  "data": "sample payload"
}

###

### Post to a topic
POST {{WebhookServer_HostAddress}}/tenants/tenant-1/topics/orders
Content-Type: application/json

{
  "orderId": "12345",
  "status": "created"
}

###

### Get requests for a topic
GET {{WebhookServer_HostAddress}}/tenants/tenant-1/topics/orders
Accept: application/json

###

### Delete requests for a topic
DELETE {{WebhookServer_HostAddress}}/tenants/tenant-1/topics/orders

### Health check
GET {{WebhookServer_HostAddress}}/healthz
